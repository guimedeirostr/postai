rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Asset Library — imagens da biblioteca de assets de marca
    match /postai-assets/{clientId}/{file} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    // Assets de canvas V3 (referências, avatares, logos)
    match /users/{uid}/clients/{clientId}/assets/{file} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Logos de clientes
    match /logos/{file} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
